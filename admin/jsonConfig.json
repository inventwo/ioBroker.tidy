{
	"i18n": true,
	"type": "tabs",
	"items": {
		"_general": {
			"type": "panel",
			"label": "General Settings",
			"items": {
				"_headerAutoScan": {
					"type": "header",
					"text": "Automatic Scanning",
					"size": 5
				},
				"autoScan": {
					"type": "checkbox",
					"label": "Enable automatic scans",
					"help": "When enabled, all configured paths will be scanned automatically at the specified interval",
					"newLine": true
				},
				"scanInterval": {
					"type": "number",
					"label": "Scan interval (hours)",
					"help": "How often the automatic scan should run (minimum 1 hour)",
					"min": 1,
					"max": 168,
					"default": 24,
					"hidden": "!data.autoScan"
				},
				"_headerThresholds": {
					"type": "header",
					"text": "Detection Thresholds",
					"size": 5,
					"newLine": true
				},
				"daysUntilStale": {
					"type": "number",
					"label": "Days until 'stale' (warning)",
					"help": "Datapoints not updated for this many days are marked as 'stale'",
					"min": 1,
					"max": 3650,
					"default": 90
				},
				"daysUntilDead": {
					"type": "number",
					"label": "Days until 'dead' (critical)",
					"help": "Datapoints not updated for this many days are marked as 'dead'",
					"min": 1,
					"max": 3650,
					"default": 365
				}
			}
		},
		"_paths": {
			"type": "panel",
			"label": "Scan Paths",
			"items": {
				"_pathsInfo": {
					"type": "staticText",
					"text": "Configure which paths to scan for unused datapoints. Each path will get its own result state with a JSON table.",
					"newLine": true
				},
				"paths": {
					"type": "table",
					"newLine": true,
					"label": "Paths to scan",
					"items": [
						{
							"type": "checkbox",
							"attr": "enabled",
							"title": "Enabled",
							"width": "10%",
							"default": true
						},
						{
							"type": "text",
							"attr": "path",
							"title": "Path (e.g. 0_userdata.0 or alias.0)",
							"width": "40%",
							"placeholder": "0_userdata.0"
						},
						{
							"type": "text",
							"attr": "name",
							"title": "Name (for result state)",
							"width": "30%",
							"placeholder": "userdata"
						},
						{
							"type": "checkbox",
							"attr": "checkAliasTargets",
							"title": "Check alias targets",
							"width": "20%",
							"default": false,
							"tooltip": "For alias.* paths: Check if target datapoints exist (ghost detection)"
						}
					]
				}
			}
		},
		"_help": {
			"type": "panel",
			"label": "Help & Documentation",
			"items": {
				"_headerFields": {
					"type": "header",
					"text": "JSON Table Field Description",
					"size": 4
				},
				"_fieldInfo": {
					"type": "staticText",
					"text": "Each scan result contains a JSON array with the following fields per datapoint:",
					"newLine": true
				},
				"_fieldTable": {
					"type": "staticText",
					"text": "<table style='width:100%; border-collapse: collapse;'><tr style='background:#2196F3;color:white;'><th style='padding:8px;text-align:left;border:1px solid #ddd;'>Field</th><th style='padding:8px;text-align:left;border:1px solid #ddd;'>Description</th><th style='padding:8px;text-align:left;border:1px solid #ddd;'>Purpose</th></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>id</code></td><td style='padding:8px;border:1px solid #ddd;'>Full datapoint path</td><td style='padding:8px;border:1px solid #ddd;'>Unique identification</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>name</code></td><td style='padding:8px;border:1px solid #ddd;'>common.name or last part of ID</td><td style='padding:8px;border:1px solid #ddd;'>User-friendly name</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>last_ts</code></td><td style='padding:8px;border:1px solid #ddd;'>Unix timestamp (ms) or null</td><td style='padding:8px;border:1px solid #ddd;'>Sorting in background</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>last_ts_iso</code></td><td style='padding:8px;border:1px solid #ddd;'>Formatted date string</td><td style='padding:8px;border:1px solid #ddd;'>Display in table</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>value</code></td><td style='padding:8px;border:1px solid #ddd;'>Current datapoint value</td><td style='padding:8px;border:1px solid #ddd;'>Final check before deletion</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>status</code></td><td style='padding:8px;border:1px solid #ddd;'>active, dead, stale, undefined, orphaned</td><td style='padding:8px;border:1px solid #ddd;'>Classification (English)</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>status_de</code></td><td style='padding:8px;border:1px solid #ddd;'>aktiv, inaktiv, veraltet, undefiniert, verwaist</td><td style='padding:8px;border:1px solid #ddd;'>Classification (German)</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>issue</code></td><td style='padding:8px;border:1px solid #ddd;'>dead, stale, orphaned_alias, or null</td><td style='padding:8px;border:1px solid #ddd;'>Filter criterion (English)</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>issue_de</code></td><td style='padding:8px;border:1px solid #ddd;'>inaktiv, veraltet, verwaistes Alias, or null</td><td style='padding:8px;border:1px solid #ddd;'>Filter criterion (German)</td></tr><tr><td style='padding:8px;border:1px solid #ddd;'><code>size</code></td><td style='padding:8px;border:1px solid #ddd;'>JSON.stringify(val).length</td><td style='padding:8px;border:1px solid #ddd;'>Finds storage hogs</td></tr></table>",
					"newLine": true
				},
				"_headerUsage": {
					"type": "header",
					"text": "Usage in VIS Widgets",
					"size": 4,
					"newLine": true
				},
				"_usageInfo": {
					"type": "staticText",
					"text": "For German tables, use the '_de' fields (status_de, issue_de) in your VIS widget column configuration. For English tables, use the regular fields (status, issue). Both field sets are always included in the JSON output.",
					"newLine": true
				}
			}
		}
	}
}