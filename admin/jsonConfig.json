{
	"i18n": true,
	"type": "tabs",
	"items": {
		"_general": {
			"type": "panel",
			"label": "General Settings",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"_headerAutoScan": {
					"type": "header",
					"text": "Automatic Scanning",
					"size": 3,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12					
				},
				"autoScan": {
					"type": "checkbox",
					"label": "Enable automatic scans",
					"help": "When enabled, all configured paths will be scanned automatically at the specified interval",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"scanAllObjects": {
					"type": "checkbox",
					"label": "Scan all objects (complete)",
					"help": "If enabled, the adapter will scan the entire object tree and store the result in a separate 'complete' result channel.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"scanInterval": {
					"type": "number",
					"label": "Scan interval (hours)",
					"help": "How often the automatic scan should run (minimum 1 hour)",
					"min": 1,
					"max": 168,
					"default": 24,
					"hidden": "!data.autoScan",
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				},
				"_headerThresholds": {
					"type": "header",
					"text": "Detection Thresholds",
					"size": 3,
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"daysUntilStale": {
					"type": "number",
					"label": "Days until 'stale' (warning)",
					"help": "Datapoints not updated for this many days are marked as 'stale'",
					"min": 1,
					"max": 3650,
					"default": 90,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				},
				"daysUntilDead": {
					"type": "number",
					"label": "Days until 'dead' (critical)",
					"help": "Datapoints not updated for this many days are marked as 'dead'",
					"min": 1,
					"max": 3650,
					"default": 365,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				}
			}
		},
		"_paths": {
			"type": "panel",
			"label": "Scan Paths",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"_headerPaths": {
					"type": "header",
					"text": "Path Configuration",
					"size": 3,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"_pathsInfo": {
					"type": "staticText",
					"text": "Configure which paths to scan for unused datapoints. Use the object picker or type a path manually. Each path will get its own result state with a JSON table.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"_pathsInstanceInfo": {
					"type": "staticText",
					"text": "Tip: The path stays editable after picking. Remove the instance number (e.g. alias.0 → alias) to scan all instances. You can also copy any object ID from the Objects tab and paste it directly into the path field.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"paths": {
					"type": "table",
					"newLine": true,
					"label": "Paths to scan",
					"showFirstAddOnTop": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"items": [
						{
							"type": "checkbox",
							"attr": "enabled",
							"title": "Enabled",
							"width": "10%",
							"default": true
						},
						{
							"type": "objectId",
							"attr": "path",
							"title": "Scan path",
							"width": "40%",
							"types": "meta",
							"tooltip": "Pick a namespace (e.g. 0_userdata.0, alias.0). The path stays editable — remove the instance number (alias.0 → alias) to scan all instances."
						},
						{
							"type": "text",
							"attr": "name",
							"title": "Name (for result state, optional)",
							"width": "30%",
							"placeholder": "Optional. If empty, the path will be used as name.",
							"tooltip": "Optional. If empty, the path will be used as name."
						},
						{
							"type": "checkbox",
							"attr": "checkAliasTargets",
							"title": "Check alias targets",
							"width": "20%",
							"default": false,
							"tooltip": "For alias.* paths: Check if target datapoints exist (ghost detection)"
						}
					]
				}
			}
		},
		"_exceptions": {
			"type": "panel",
			"label": "Exceptions",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"_headerExceptions": {
					"type": "header",
					"text": "Excluded datapoints",
					"size": 3,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"_exceptionsInfo": {
					"type": "staticText",
					"text": "Exclude datapoints from scan results that are intentionally static or should be ignored. Use the picker to select individual datapoints. To exclude an entire folder, type the path manually (e.g. 0_userdata.0.config).",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"exceptions": {
					"type": "table",
					"newLine": true,
					"label": "Excluded datapoints",
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"items": [
					{
						"type": "objectId",
						"attr": "id",
						"title": "Object",
						"width": "55%",
						"types": "state",
						"tooltip": "Pick an individual datapoint to exclude it. To exclude an entire folder, type the folder path directly (e.g. 0_userdata.0.config)."
					},
						{
							"type": "text",
							"attr": "comment",
							"title": "Comment (optional)",
							"width": "45%",
							"placeholder": "Optional note, e.g. alarm clock radio station"
						}
					]
				}
			}
		},
		"_help": {
			"type": "panel",
			"label": "Help & Documentation",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"_headerScanPathsHelp": {
					"type": "header",
					"text": "Scan Paths",
					"size": 3,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"_scanPathsHelpInfo": {
					"type": "staticText",
					"text": "Use the object picker on the Scan Paths tab or type a path manually. The path stays editable after picking.\n\nTo scan all instances of an adapter, remove the instance number from the path (e.g. alias.0 → alias). This matches alias.0, alias.1, and so on.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem",
						"whiteSpace": "pre-line"
					}
				},
				"_headerExceptionsHelp": {
					"type": "header",
					"text": "Exceptions",
					"size": 3,
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"_exceptionsHelpInfo": {
					"type": "staticText",
					"text": "Datapoints listed on the Exceptions tab are omitted from all scan results and statistics. Use this for configuration values that rarely change but should not appear as dead or stale.\n\nUse the picker to select individual datapoints (states). To exclude an entire folder or subtree, type the path directly into the field (e.g. 0_userdata.0.config).\n\nEach scan channel provides exceptionCount showing how many datapoints were excluded during the last scan (0 if none).",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem",
						"whiteSpace": "pre-line"
					}
				},
				"_headerFields": {
					"type": "header",
					"text": "JSON Table Field Description",
					"size": 3,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"_fieldInfo": {
					"type": "staticText",
					"text": "Each scan result contains a JSON array with the following fields per datapoint:",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"help_json_fields": {
					"type": "staticText",
					"text": "help_json_fields",
					"format": "html",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem",
						"marginBottom": "16px"
					}
				},
				"_headerUsage": {
					"type": "header",
					"text": "Usage in VIS Widgets",
					"size": 3,
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"_usageInfo": {
					"type": "staticText",
					"text": "For German tables: Use status_de and issue_de columns\nFor English tables: Use status and issue columns\n\nFilter by 'issue != null' to show only problematic datapoints.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "0.875rem",
						"whiteSpace": "pre-line"
					}
				},
				"help_readme": {
					"type": "staticText",
					"text": "help_readme",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12,
					"style": {
						"fontSize": "1rem",
						"marginBottom": "16px"
					}
				},
				"_helpDivider": {
					"type": "divider"
				},
				"help_logo": {
					"type": "staticImage",
					"src": "img/inventwo.svg",
					"newLine": true,
					"sm": 0.5,
					"xs": 0.5,
					"md": 0.5,
					"lg": 0.5,
					"xl": 0.5,
					"style": {
						"marginTop": "25px"
					}
				},
				"help_outro": {
					"type": "staticText",
					"text": "Team inventwo •  <a href=\"https://github.com/inventwo\">https://github.com/inventwo</a> • by skvarel",
					"newLine": true,
					"sm": 12,
					"xs": 12,
					"md": 3,
					"lg": 3,
					"xl": 3,
					"style": {
						"borderTop": "0px solid",
						"borderColor": "",
						"marginTop": "0px",
						"paddingTop": "5px",
						"fontSize": "14px",
						"textAlign": "left"
					}
				},
				"help_paypal": {
					"type": "staticLink",
					"href": "https://www.paypal.com/donate/?hosted_button_id=7W6M3TFZ4W9LW",
					"target": "_blank",
					"label": "paypal_donate",
					"variant": "outlined",
					"button": true,
					"icon": "https://www.paypalobjects.com/marketing/web/logos/paypal-mark-color_new.svg",
					"newLine": true,
					"sm": 12,
					"xs": 12,
					"md": 3,
					"lg": 3,
					"xl": 3,
					"style": {
						"marginTop": "0px"
					}
				}
			}
		}
	}
}