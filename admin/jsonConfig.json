{
	"i18n": true,
	"type": "tabs",
	"items": {
		"_general": {
			"type": "panel",
			"label": "General Settings",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"_headerAutoScan": {
					"type": "header",
					"text": "Automatic Scanning",
					"size": 3
				},
				"autoScan": {
					"type": "checkbox",
					"label": "Enable automatic scans",
					"help": "When enabled, all configured paths will be scanned automatically at the specified interval",
					"newLine": true,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"scanInterval": {
					"type": "number",
					"label": "Scan interval (hours)",
					"help": "How often the automatic scan should run (minimum 1 hour)",
					"min": 1,
					"max": 168,
					"default": 24,
					"hidden": "!data.autoScan"
				},
				"_headerThresholds": {
					"type": "header",
					"text": "Detection Thresholds",
					"size": 3,
					"newLine": true
				},
				"daysUntilStale": {
					"type": "number",
					"label": "Days until 'stale' (warning)",
					"help": "Datapoints not updated for this many days are marked as 'stale'",
					"min": 1,
					"max": 3650,
					"default": 90
				},
				"daysUntilDead": {
					"type": "number",
					"label": "Days until 'dead' (critical)",
					"help": "Datapoints not updated for this many days are marked as 'dead'",
					"min": 1,
					"max": 3650,
					"default": 365
				}
			}
		},
		"_paths": {
			"type": "panel",
			"label": "Scan Paths",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"_headerPaths": {
					"type": "header",
					"text": "Path Configuration",
					"size": 3
				},
				"_pathsInfo": {
					"type": "staticText",
					"text": "Configure which paths to scan for unused datapoints. Each path will get its own result state with a JSON table.",
					"newLine": true,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"paths": {
					"type": "table",
					"newLine": true,
					"label": "Paths to scan",
					"items": [
						{
							"type": "checkbox",
							"attr": "enabled",
							"title": "Enabled",
							"width": "10%",
							"default": true
						},
						{
							"type": "text",
							"attr": "path",
							"title": "Path (e.g. 0_userdata.0 or alias.0)",
							"width": "40%",
							"placeholder": "0_userdata.0"
						},
						{
							"type": "text",
							"attr": "name",
							"title": "Name (for result state)",
							"width": "30%",
							"placeholder": "userdata"
						},
						{
							"type": "checkbox",
							"attr": "checkAliasTargets",
							"title": "Check alias targets",
							"width": "20%",
							"default": false,
							"tooltip": "For alias.* paths: Check if target datapoints exist (ghost detection)"
						}
					]
				}
			}
		},
		"_help": {
			"type": "panel",
			"label": "Help & Documentation",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"_headerFields": {
					"type": "header",
					"text": "JSON Table Field Description",
					"size": 3
				},
				"_fieldInfo": {
					"type": "staticText",
					"text": "Each scan result contains a JSON array with the following 10 fields per datapoint:",
					"newLine": true,
					"style": {
						"fontSize": "0.875rem"
					}
				},
				"fieldDocs": {
					"type": "table",
					"newLine": true,
					"noDelete": true,
					"compact": true,
					"items": [
						{
							"type": "text",
							"attr": "pos",
							"title": "Pos.",
							"width": "1%",
							"readOnly": true
						},
						{
							"type": "text",
							"attr": "field",
							"title": "Field",
							"width": "10%",
							"readOnly": true
						},
						{
							"type": "text",
							"attr": "description",
							"title": "Description",
							"width": "30%",
							"readOnly": true
						},
						{
							"type": "text",
							"attr": "purpose",
							"title": "Purpose",
							"readOnly": true
						}
					]
				},
				"_headerUsage": {
					"type": "header",
					"text": "Usage in VIS Widgets",
					"size": 3,
					"newLine": true
				},
				"_usageInfo": {
					"type": "staticText",
					"text": "For German tables: Use status_de and issue_de columns\nFor English tables: Use status and issue columns\n\nFilter by 'issue != null' to show only problematic datapoints.",
					"newLine": true,
					"style": {
						"fontSize": "0.875rem"
					}
				}
			}
		}
	}
}