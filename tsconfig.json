{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "lib": ["es2024"],
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "strict": false,
        "strictNullChecks": false,
        "resolveJsonModule": true
    },
    "include": ["**/*.ts", "lib/**/*.d.ts"],
    "exclude": ["node_modules/**", "test/**", "admin/**", "build/**"]
}
